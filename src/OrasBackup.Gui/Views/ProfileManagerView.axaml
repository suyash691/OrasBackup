<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OrasBackup.Gui.ViewModels"
             x:Class="OrasBackup.Gui.Views.ProfileManagerView"
             x:DataType="vm:ProfileManagerViewModel">

    <Grid ColumnDefinitions="*,*" Margin="8">
        <!-- Left: Profile list -->
        <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,8,0">
            <TextBlock Text="Profiles" FontWeight="Bold" FontSize="16" />
            <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" MinHeight="200" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="New" Command="{Binding NewProfileCommand}" />
                <Button Content="Delete" Command="{Binding DeleteProfileCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Right: Edit form -->
        <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
            <TextBlock Text="{Binding IsEditing, StringFormat='{}Edit Profile'}"
                       FontWeight="Bold" FontSize="16" />
            <TextBox PlaceholderText="Profile name" Text="{Binding EditName}" />
            <TextBox PlaceholderText="Source paths (comma-separated)" Text="{Binding EditSource}" />
            <TextBox PlaceholderText="Registry (e.g. ghcr.io/user/backups)" Text="{Binding EditRegistry}" />
            <TextBox PlaceholderText="Auth token (PAT for GHCR, optional)" Text="{Binding EditAuthToken}" PasswordChar="•" />
            <CheckBox Content="Encryption enabled" IsChecked="{Binding EditEncryption}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Max backups:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding EditMaxBackups}" Minimum="1" Maximum="1000" Width="100" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Create" Command="{Binding CreateProfileCommand}" IsVisible="{Binding !IsEditing}" />
                <Button Content="Save" Command="{Binding SaveProfileCommand}" IsVisible="{Binding IsEditing}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
