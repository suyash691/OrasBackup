# === Required ===
ORASBACKUP_REGISTRY=registry.example.com/myuser/backups/nas-docs

# === Encryption (pick one) ===
ORASBACKUP_PASSWORD=my-secret-password
# ORASBACKUP_KEY_FILE=/config/backup.key

# === Optional: Override defaults ===
# ORASBACKUP_PROFILE=default
# ORASBACKUP_SOURCE=/data
# ORASBACKUP_INTERVAL=360              # minutes (360 = 6 hours)
# ORASBACKUP_ENCRYPT=true
# ORASBACKUP_EXCLUDE=**/.git,**/node_modules,**/bin,**/obj,**/.DS_Store
# ORASBACKUP_MAX_BACKUPS=50
# ORASBACKUP_COMPACT_AFTER=10

# === Registry auth ===
# Option 1: PAT (GitHub Container Registry, GitLab, etc.)
# ORAS_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
#
# Option 2: Username + password/token
# ORAS_USERNAME=myuser
# ORAS_PASSWORD=mytoken
#
# For plain HTTP registries (local/dev):
# ORAS_INSECURE=true

# === Advanced ===
# ORASBACKUP_CONFIG_DIR=/config
